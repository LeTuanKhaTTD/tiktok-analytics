# YouTube Analytics Configuration Template
# Copy file này thành .env và điền thông tin thực tế

# ===== YOUTUBE API =====
YOUTUBE_API_KEY=your_youtube_api_key_here

# ===== GEMINI AI (Added 2026-03-11) =====
# Get your API key from: https://aistudio.google.com/
# Free tier: 15 requests/minute, 1,500 requests/day
GEMINI_API_KEY=your_gemini_api_key_here

# ===== TIKTOK API (Optional) =====
TIKTOK_CLIENT_KEY=your_tiktok_client_key_here
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret_here

# ===== ANALYSIS SETTINGS =====
DEFAULT_VIDEO_COUNT=30
DEFAULT_COMMENTS_PER_VIDEO=50
USE_VIETNAMESE=True
USE_TRANSFORMERS=False

# ===== OUTPUT SETTINGS =====
OUTPUT_DIR=data
REPORTS_DIR=reports

# ===== FULL-STACK PLATFORM (FastAPI + Supabase + HuggingFace) =====
JWT_SECRET_KEY=change-this-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
CORS_ORIGINS_RAW=http://localhost:8501,http://127.0.0.1:8501

SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

HF_API_TOKEN=your_huggingface_token
HF_MODEL_ID=LeTuanKhaTTD/phobert-tvu-sentiment

# Frontend Streamlit app (frontend/app.py) will read this from secrets first.
API_BASE_URL=http://127.0.0.1:8000
